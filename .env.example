# Hugo Teek Admin Server 环境变量配置模板
#
# 此文件是模板，用于生成和同步 .env 文件
# 运行 init-env.bat/init-env.sh 时：
#   - 首次：从此文件创建 .env
#   - 后续：仅添加 .env 中缺失的新变量（不覆盖现有值）
# __PROJECT_ROOT__ 占位符会被自动替换为项目的绝对路径
#

# ==================== 项目路径配置 ====================
# 项目根目录（绝对路径，自动检测）
HUGO_TEEK_BASE_DIR=__PROJECT_ROOT__

# Hugo 站点目录
HUGO_TEEK_SITE_DIR=${HUGO_TEEK_BASE_DIR}/hugo-teek-site

# 数据目录（存放 JSON 数据文件）
HUGO_TEEK_DATA_DIR=${HUGO_TEEK_BASE_DIR}/hugo-teek-site/data

# 静态资源目录
HUGO_TEEK_STATIC_DIR=${HUGO_TEEK_BASE_DIR}/hugo-teek-site/static

# 内容目录
HUGO_TEEK_CONTENT_DIR=${HUGO_TEEK_BASE_DIR}/hugo-teek-site/content

# 配置文件路径
HUGO_TEEK_CONFIG=${HUGO_TEEK_BASE_DIR}/hugo-teek-site/hugo.toml

# ==================== 服务器配置 ====================
# Linux 环境端口配置（默认）
HUGO_TEEK_PORT=8888          # 后端管理服务器端口
HUGO_TEEK_HUGO_PORT=8090     # Hugo 开发服务器端口
HUGO_TEEK_VITE_PORT=5173     # Vite 前端开发服务器端口

# 注意：Windows 环境会自动将端口调整为 9888/9090/6173（Linux 端口 + 1000）
# 如需自定义端口，请在生成的 .env 文件中手动修改

# 服务主机地址
HUGO_TEEK_HOST=0.0.0.0

# 运行模式 (debug|release)
HUGO_TEEK_MODE=debug

# ==================== 图库配置 ====================
# 图库数据文件
GALLERY_DATA_FILE=${HUGO_TEEK_DATA_DIR}/gallery.json

# 相册数据文件
ALBUMS_DATA_FILE=${HUGO_TEEK_DATA_DIR}/albums.json

# 图片上传目录
GALLERY_UPLOAD_DIR=${HUGO_TEEK_STATIC_DIR}/images

# 图片转换设置
IMAGE_CONVERT_ENABLED=true
IMAGE_CONVERT_QUALITY=85

# ==================== 菜单配置 ====================
# 菜单数据文件
MENU_DATA_FILE=${HUGO_TEEK_DATA_DIR}/menus.json
